# Railway PostgreSQL
# Railwayダッシュボード → PostgreSQL → Variables の DATABASE_URL をコピー
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Auth.js
# `openssl rand -hex 32` で生成
AUTH_SECRET=CHANGE_ME
# 開発時は http://localhost:3000、本番はVercelのURL
AUTH_URL=http://localhost:3000

# Google OAuth
# https://console.cloud.google.com/apis/credentials で作成
# Authorized redirect URIs: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Web Push (VAPID) - npm run generate:vapid で生成
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:refarmkobe@gmail.com

# Vercel Cron 認証用 (`openssl rand -hex 32`)
CRON_SECRET=

# Gemini API (食品推論用)
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=
